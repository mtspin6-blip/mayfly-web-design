---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';

const services = [
  {
    name:   'Local SEO',
    detail: 'Google Business Profile optimization, NAP consistency across directories, and local citation building',
  },
  {
    name:   'On-Page SEO',
    detail: 'Title tags, meta descriptions, schema markup, header structure — every page dialed in',
  },
  {
    name:   'GAIO Setup',
    detail: 'Schema for AI parsing, FAQ structures, factual claims, and source signals that get you cited by ChatGPT, Claude & Perplexity',
  },
  {
    name:   'Tracking',
    detail: 'Monthly report covering Google rankings, Map Pack visibility, and AI citation tracking',
  },
  {
    name:   'Content Strategy',
    detail: 'What to write, in what order, targeting which queries — a roadmap, not a guess',
  },
];

const steps = [
  { n: '01', title: 'SEO Audit',           note: 'Current state report — where you rank, what\'s broken, what\'s being missed' },
  { n: '02', title: 'Quick Wins',           note: 'Week 1–2: low-hanging fruit that moves the needle fast' },
  { n: '03', title: 'Foundation Build',     note: 'Week 3–6: schema, citations, content structure, and GAIO-ready markup' },
  { n: '04', title: 'Ongoing Optimization', note: 'Monthly: content creation, ranking updates, and AI citation tracking' },
];

const faqs = [
  {
    q: 'How fast will I rank?',
    a: 'Local SEO: expect meaningful movement in 4–8 weeks. GAIO (AI search) is faster — 2–4 weeks — because there\'s far less competition. Early movers have a real advantage right now.',
  },
  {
    q: 'Is GAIO worth it now?',
    a: 'Yes. AI-generated answers are already replacing the first page of Google for millions of queries. Most of your competitors aren\'t optimizing for this yet. That\'s an opening.',
  },
  {
    q: 'What if I already have an SEO person?',
    a: 'We can complement what they\'re doing — specifically adding GAIO work they likely aren\'t covering — or we can take over entirely. Either way, we start with an audit before making any recommendations.',
  },
  {
    q: 'What is GAIO and how is it different from regular SEO?',
    a: 'GAIO (Generative AI Optimization) is how you get cited by AI tools like ChatGPT, Claude, and Perplexity. Traditional SEO optimizes for search engine rankings. GAIO optimizes for AI-generated answer citations — a separate and growing channel.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<BaseLayout
  title="Montana SEO + GAIO Services | Mayfly Web Design"
  description="Rank locally and get cited by AI. Full local SEO and Generative AI Optimization (GAIO) for Montana businesses — Missoula, Bozeman, statewide."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head"></script>
  <Header />
  <main id="main-content">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="svc-hero">
      <div class="svc-favicon" aria-hidden="true">
        <img src="/BugTransparentLogo.svg" alt="" width="72" height="72" />
      </div>
      <div class="section-container svc-hero-inner">
        <div class="svc-hero-content">
          <p class="section-eyebrow reveal">SEO &amp; GAIO</p>
          <h1 class="svc-headline reveal" style="transition-delay:0.08s">
            Get found — by Google<br /><em>and ChatGPT.</em>
          </h1>
          <p class="svc-sub reveal" style="transition-delay:0.16s">
            Most agencies optimize for Google in 2015. We optimize for how Montanans
            actually search today: Google, Maps, ChatGPT, Claude, and Perplexity.
          </p>
          <a href="/contact/" class="btn-primary reveal" style="transition-delay:0.22s">
            Book a Free Consultation
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <div class="hero-bug" aria-hidden="true">
          <img src="/BugTransparentLogo.svg" alt="" width="260" height="260" />
        </div>
      </div>
    </section>

    <!-- ── Problem ───────────────────────────────────────── -->
    <section class="problem-section">
      <div class="section-container">
        <div class="problem-inner reveal">
          <p class="problem-eyebrow">The Problem</p>
          <blockquote class="problem-quote">
            "AI search is here. When someone asks ChatGPT
            <em>'best HVAC company in Bozeman,'</em>
            your business needs to show up. Traditional SEO won't get you there."
          </blockquote>
        </div>
      </div>
    </section>

    <!-- ── What is GAIO ───────────────────────────────────── -->
    <section class="gaio-explain-section">
      <div class="section-container">
        <div class="gaio-callout reveal">
          <div class="gaio-callout-inner">
            <p class="gaio-label">What is GAIO?</p>
            <h2 class="gaio-headline">Generative AI Optimization</h2>
            <p class="gaio-body">
              GAIO is how you get cited by AI tools like ChatGPT, Claude, and Perplexity
              when people ask questions about your industry or location.
              When someone types "best fly fishing guide in Missoula" into an AI,
              GAIO is what puts your business in the answer.
            </p>
            <p class="gaio-body" style="margin-top:1rem">
              It uses structured content, schema markup, and factual signals that
              AI models are trained to surface and trust. Traditional keyword SEO
              alone won't do it.
            </p>
            <p class="gaio-body" style="margin-top:1rem">
              <strong>Question:</strong> "What is GAIO for a small business?"<br />
              <strong>Answer:</strong> GAIO (Generative AI Optimization) is the practice of structuring
              your website content, schema markup, and factual signals so AI models
              like ChatGPT, Claude, and Perplexity cite your business in their answers.
              It's the new frontier of search visibility.
            </p>
          </div>
          <div class="gaio-ai-logos" aria-label="AI tools we optimize for">
            <span class="ai-tag">ChatGPT</span>
            <span class="ai-tag">Claude</span>
            <span class="ai-tag">Perplexity</span>
            <span class="ai-tag">Google SGE</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Services ───────────────────────────────────────── -->
    <section class="services-section">
      <div class="section-container">
        <div class="reveal">
          <p class="section-eyebrow">What You Get</p>
          <h2 class="section-headline" style="margin-bottom:3rem">
            Full-stack SEO.<br /><em>Built for Montana.</em>
          </h2>
        </div>
        <div class="svc-grid">
          {services.map((s, i) => (
            <div class="svc-card reveal" style={`transition-delay:${i * 0.07}s`}>
              <h3 class="svc-name">{s.name}</h3>
              <p class="svc-detail">{s.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Process ───────────────────────────────────────── -->
    <section class="process-section">
      <div class="section-container">
        <div class="reveal">
          <p class="section-eyebrow">How It Works</p>
          <h2 class="section-headline" style="margin-bottom:3rem">
            Audit first,<br /><em>build on facts.</em>
          </h2>
        </div>
        <ol class="process-list" role="list">
          {steps.map((s, i) => (
            <li class="process-step reveal" style={`transition-delay:${i * 0.08}s`}>
              <span class="step-n" aria-hidden="true">{s.n}</span>
              <div class="step-body">
                <h3 class="step-title">{s.title}</h3>
                <p class="step-note">{s.note}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ── Bug divider ─────────────────────────────────────── -->
    <div class="bug-divider" aria-hidden="true">
      <img src="/BugTransparentLogo.svg" alt="" width="72" height="72" />
    </div>

    <!-- ── Pricing Teaser ─────────────────────────────────── -->
    <section class="pricing-teaser">
      <div class="section-container pricing-teaser-inner reveal">
        <div>
          <p class="section-eyebrow">Investment</p>
          <p class="teaser-price">$1,500 setup + $500/mo</p>
          <p class="teaser-note">One-time foundation + ongoing monthly optimization and tracking</p>
        </div>
        <a href="/pricing/" class="btn-secondary teaser-cta">
          See Full Pricing
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────── -->
    <section class="faq-section">
      <div class="section-container">
        <div class="reveal">
          <p class="section-eyebrow">FAQ</p>
          <h2 class="section-headline" style="margin-bottom:3rem">Common questions</h2>
        </div>
        <dl class="faq-list">
          {faqs.map((f, i) => (
            <div class="faq-item reveal" style={`transition-delay:${i * 0.1}s`}>
              <dt class="faq-q">{f.q}</dt>
              <dd class="faq-a">{f.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Favicon — top-right */
  .svc-favicon {
    position: absolute;
    top: 1.5rem;
    right: clamp(1.25rem, 5vw, 4rem);
    z-index: 3;
    width: 70px;
    height: 70px;
    filter: brightness(0) invert(1) drop-shadow(0 2px 8px rgba(0,0,0,0.6));
    opacity: 0.88;
    pointer-events: none;
  }
  .svc-favicon img { width: 100%; height: auto; display: block; }

  /* ── Hero ────────────────────────── */
  .svc-hero {
    background-color: var(--color-text);
    padding: 5rem 0 4.5rem;
    border-bottom: 1px solid rgba(242,237,227,0.08);
    overflow: hidden;
    position: relative;
  }
  .svc-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1446776811953-b23d57bd21aa?w=1920&auto=format&fit=crop&q=80');
    background-size: cover;
    background-position: center 40%;
    z-index: 0;
  }
  .svc-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: rgba(22, 22, 20, 0.55);
    z-index: 1;
  }
  .svc-hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  @media (min-width: 1024px) {
    .svc-hero-inner { grid-template-columns: 1fr auto; gap: 4rem; }
  }
  .svc-hero-content { max-width: 640px; }
  .hero-bug {
    display: none;
    opacity: 0.18;
    flex-shrink: 0;
    filter: brightness(0) invert(1);
  }
  @media (min-width: 1024px) {
    .hero-bug { display: block; }
    .hero-bug img { width: clamp(160px, 20vw, 280px); height: auto; }
  }

  .svc-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    line-height: 1.07;
    letter-spacing: -0.025em;
    color: var(--color-bg);
    margin-bottom: 1.375rem;
  }
  .svc-headline em { font-style: italic; color: var(--color-accent); }
  .svc-sub {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    font-weight: 300;
    line-height: 1.72;
    color: rgba(242,237,227,0.72);
    max-width: 48ch;
    margin-bottom: 2.25rem;
  }

  /* ── Problem ─────────────────────── */
  .problem-section {
    background-color: var(--color-text);
    padding: 5rem 0;
  }
  .problem-inner { max-width: 740px; }
  .problem-eyebrow {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.75rem;
  }
  .problem-quote {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.375rem, 3.5vw, 2.25rem);
    line-height: 1.45;
    color: rgba(242,237,227,0.88);
    margin: 0;
    quotes: none;
  }
  .problem-quote em { font-style: normal; color: var(--color-accent); font-weight: 400; }

  /* ── GAIO explainer ───────────────── */
  .gaio-explain-section {
    background-color: var(--color-surface);
    padding: 5.5rem 0;
  }
  .gaio-callout {
    background-color: var(--color-text);
    padding: 3.5rem 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .gaio-callout { grid-template-columns: 3fr 1fr; align-items: start; gap: 5rem; }
  }
  .gaio-label {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }
  .gaio-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    letter-spacing: -0.025em;
    color: var(--color-bg);
    margin-bottom: 1.25rem;
    line-height: 1.12;
  }
  .gaio-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.72;
    color: rgba(242,237,227,0.7);
    max-width: 58ch;
  }
  .gaio-body strong {
    color: rgba(242,237,227,0.9);
    font-weight: 500;
  }
  .gaio-ai-logos {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-self: center;
  }
  @media (min-width: 1024px) {
    .gaio-ai-logos { padding-top: 2.5rem; }
  }
  .ai-tag {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(242,237,227,0.75);
    padding: 0.5rem 1rem;
    border: 1px solid rgba(242,237,227,0.15);
    text-align: center;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .ai-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Services ────────────────────── */
  .services-section {
    background-color: var(--color-surface);
    padding: 5.5rem 0 5rem;
  }
  .svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5px;
    background-color: var(--color-surface);
  }
  @media (min-width: 768px) { .svc-grid { grid-template-columns: 1fr 1fr; } }

  .svc-card {
    background-color: var(--color-bg);
    padding: 2.25rem 2rem;
    border-top: 2px solid var(--color-accent);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background-color 0.15s ease, transform 0.15s ease;
  }
  .svc-card:hover {
    background-color: var(--color-surface);
    transform: translateY(-2px);
  }
  .svc-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .svc-detail {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-muted);
  }

  /* ── Process ─────────────────────── */
  .process-section {
    background-color: var(--color-bg);
    padding: 5.5rem 0;
  }
  @media (min-width: 768px) { .process-section { padding: 7rem 0; } }

  .process-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-surface);
  }
  .process-step {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-surface);
    align-items: start;
    transition: padding-left 0.2s ease;
  }
  .process-step:hover { padding-left: 0.5rem; }
  .step-n {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-muted);
    padding-top: 0.35rem;
  }
  .step-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.375rem;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin-bottom: 0.375rem;
  }
  .step-note {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-muted);
  }

  /* ── Bug divider ─────────────────── */
  .bug-divider {
    display: flex;
    justify-content: center;
    padding: 2.5rem 0 1rem;
    background-color: var(--color-surface);
  }
  .bug-divider img { opacity: 0.18; }

  /* ── Pricing teaser ─────────────── */
  .pricing-teaser {
    background-color: var(--color-surface);
    padding: 4.5rem 0;
    border-top: 1px solid var(--color-muted);
    border-bottom: 1px solid var(--color-muted);
  }
  .pricing-teaser-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .pricing-teaser-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
  .teaser-price {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.625rem, 4vw, 2.5rem);
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .teaser-note {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--color-muted);
  }
  .teaser-cta { gap: 0.5rem; }

  /* ── FAQ ─────────────────────────── */
  .faq-section {
    background-color: var(--color-bg);
    padding: 5.5rem 0;
  }
  @media (min-width: 768px) { .faq-section { padding: 7rem 0; } }

  .faq-list {
    max-width: 680px;
    border-top: 1px solid var(--color-surface);
  }
  .faq-item {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-surface);
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }
  .faq-a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.72;
    color: var(--color-muted);
    max-width: 58ch;
    margin: 0;
  }

  @media (max-width: 767px) {
    .teaser-cta { width: 100%; justify-content: center; }
  }
</style>
