---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroImg from '../../assets/BlogPageHeader.jpg';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const heroImage = await getImage({ src: HeroImg, width: 1920, format: 'webp', quality: 82 });

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Mayfly Web Design Blog",
  "description": "Web design, AI search, and GAIO insights for Montana small businesses",
  "url": "https://mayflywebdesign.com/blog",
  "publisher": {
    "@type": "LocalBusiness",
    "name": "Mayfly Web Design",
    "url": "https://mayflywebdesign.com"
  }
};
---

<BaseLayout
  title="Montana Web Design & AI Search Blog | Mayfly Web Design"
  description="Insights on web design, AI search optimization, and GAIO for Montana small businesses. Built for guides, breweries, restaurants, and trades."
>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} slot="head"></script>

  <Header />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section
      class="blog-hero"
      style={`background-image: url('${heroImage.src}')`}
      aria-label="Blog hero"
    >
      <div class="blog-hero-overlay" aria-hidden="true"></div>

      <div class="section-container blog-hero-content">
        <p class="blog-hero-eyebrow">Field Notes</p>
        <h1 class="blog-hero-headline">The Mayfly Blog</h1>
        <p class="blog-hero-sub">Web design, AI search, and digital strategy for Montana businesses.</p>
      </div>
    </section>

    <!-- ── Post Grid ─────────────────────────────────────────── -->
    <section class="blog-grid-section">
      <div class="section-container">

        {posts.length === 0 ? (
          <div class="blog-empty reveal">
            <p>More posts coming soon. <a href="mailto:contact@mayflywebdesign.com">Get in touch.</a></p>
          </div>
        ) : (
          <ul class="blog-grid" role="list">
            {posts.map((post, i) => (
              <li
                class="blog-card reveal"
                data-category={post.data.category}
                style={`transition-delay: ${i * 0.08}s`}
              >
                <a href={`/blog/${post.slug}/`} class="blog-card-link" tabindex="-1" aria-hidden="true"></a>
                <div class="blog-card-top">
                  <span class="blog-tag">{post.data.category}</span>
                  <span class="blog-read-time">{post.data.readTime}</span>
                </div>
                <h2 class="blog-card-title">
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card-excerpt">{post.data.excerpt}</p>
                <div class="blog-card-footer">
                  <a href={`/blog/${post.slug}/`} class="blog-read-more">
                    Read More <span class="read-arrow" aria-hidden="true">→</span>
                  </a>
                  <time class="blog-date" datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', {
                      year: 'numeric', month: 'long', day: 'numeric'
                    })}
                  </time>
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <!-- ── CTA Strip ─────────────────────────────────────────── -->
    <section class="blog-cta-strip">
      <div class="section-container blog-cta-inner reveal">
        <p class="blog-cta-headline">Want results like this for your business?</p>
        <a
          href="https://cal.com/mtspin6"
          target="_blank"
          rel="noopener noreferrer"
          class="blog-cta-btn"
        >
          Book a Free Call
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .blog-hero {
    position: relative;
    min-height: 280px;
    background-size: cover;
    background-position: center 35%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  @media (min-width: 768px) {
    .blog-hero { min-height: 400px; }
  }

  .blog-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(22, 22, 20, 0.62);
    z-index: 0;
  }

  .blog-hero-content {
    position: relative;
    z-index: 1;
    padding-bottom: 3.5rem;
    padding-top: 6rem;
  }
  @media (min-width: 768px) {
    .blog-hero-content { padding-bottom: 5rem; }
  }

  .blog-hero-eyebrow {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
    animation: heroFadeUp 0.5s ease-out 0.05s both;
  }

  .blog-hero-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-bg);
    margin-bottom: 1rem;
    text-shadow: 0 4px 12px rgba(22, 22, 20, 0.5);
    animation: heroFadeUp 0.6s ease-out 0.1s both;
  }

  .blog-hero-sub {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 300;
    color: rgba(242, 237, 227, 0.82);
    max-width: 44ch;
    line-height: 1.65;
    animation: heroFadeUp 0.5s ease-out 0.3s both;
  }

  /* Load animations */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-hero-logo,
    .blog-hero-eyebrow,
    .blog-hero-headline,
    .blog-hero-sub {
      animation: none;
    }
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .blog-grid-section {
    background-color: var(--color-bg);
    padding: 5rem 0 6rem;
  }

  .blog-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  @media (min-width: 768px) {
    .blog-grid { grid-template-columns: 1fr 1fr; }
  }

  /* ── Card base ────────────────────────────────────────────── */
  .blog-card {
    position: relative;
    background-color: #fff;
    border: 1px solid var(--color-surface);
    border-left: 2px solid var(--color-accent); /* default: sage green */
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    box-shadow: 0 4px 12px rgba(22, 22, 20, 0.08);
    transition: box-shadow 0.3s ease, transform 0.3s ease, background-color 0.3s ease;
  }
  .blog-card:hover {
    box-shadow: 0 8px 24px rgba(22, 22, 20, 0.13);
    transform: translateY(-4px);
  }

  /* ── Category variants ────────────────────────────────────── */

  /* Web Design + AI Search — Sage Green (default, no override needed) */
  .blog-card[data-category="Web Design"]:hover,
  .blog-card[data-category="AI Search"]:hover {
    background-color: rgba(94, 126, 88, 0.04);
  }

  /* Automations — Gold */
  .blog-card[data-category="Automations"] {
    border-left-color: var(--color-gold);
  }
  .blog-card[data-category="Automations"] .blog-tag {
    background-color: var(--color-gold);
  }
  .blog-card[data-category="Automations"]:hover {
    background-color: rgba(184, 136, 46, 0.05);
  }

  /* SEO — Warm Black border, white background */
  .blog-card[data-category="SEO"] {
    border-left-color: var(--color-text);
  }
  .blog-card[data-category="SEO"] .blog-tag {
    background-color: var(--color-text);
  }

  /* Pricing — gradient left border via pseudo-element */
  .blog-card[data-category="Pricing"] {
    border-left-color: transparent;
  }
  .blog-card[data-category="Pricing"]::before {
    content: '';
    position: absolute;
    left: -1px;
    top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-accent) 67%, var(--color-gold) 100%);
    pointer-events: none;
  }
  .blog-card[data-category="Pricing"]:hover {
    background-color: rgba(94, 126, 88, 0.03);
  }

  /* invisible full-card link overlay */
  .blog-card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .blog-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.125rem;
  }

  .blog-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-bg);
    background-color: var(--color-accent);
    padding: 0.3rem 0.75rem;
  }

  .blog-read-time {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-muted);
    font-weight: 300;
    font-style: italic;
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: #161614;
    margin-bottom: 0.875rem;
  }
  .blog-card-title a {
    text-decoration: none;
    color: inherit;
    position: relative;
    z-index: 1;
  }
  .blog-card-title a:hover { color: var(--color-gold); }

  .blog-card-excerpt {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.68;
    color: #6B6B69;
    margin-bottom: 1.75rem;
    flex: 1;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-surface);
  }

  .blog-read-more {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-gold);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    position: relative;
    z-index: 1;
    transition: gap 0.18s ease;
  }
  .blog-read-more:hover { gap: 0.6rem; }
  .read-arrow { transition: transform 0.18s ease; }
  .blog-read-more:hover .read-arrow { transform: translateX(3px); }

  .blog-date {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: #ABABAB;
    font-weight: 300;
    white-space: nowrap;
  }

  /* ── Empty state ──────────────────────────────────────────── */
  .blog-empty {
    text-align: center;
    padding: 4rem 0;
    font-family: var(--font-body);
    color: var(--color-muted);
  }
  .blog-empty a {
    color: var(--color-gold);
    text-decoration: underline;
  }

  /* ── CTA Strip ────────────────────────────────────────────── */
  .blog-cta-strip {
    background-color: var(--color-accent);
    padding: 3.5rem 0;
  }

  .blog-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .blog-cta-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .blog-cta-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-bg);
  }

  .blog-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0.875rem 2rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    background-color: var(--color-bg);
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .blog-cta-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* ── Reduced motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .blog-card {
      transition: none;
    }
    .blog-card:hover {
      transform: none;
    }
    .blog-read-more,
    .read-arrow {
      transition: none;
    }
  }
</style>
