---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Contact Mayfly Web Design | Montana Web Design Agency"
  description="Book a free 30-minute discovery call or send a message. Montana web design, AI automations & SEO. Response within 1 business day."
>
  <Header />
  <main id="main-content">
    <section class="contact-hero">
      <div class="contact-hero-photo" aria-hidden="true"></div>
      <div class="contact-hero-dim"   aria-hidden="true"></div>
      <div class="section-container" style="position:relative;z-index:2">
        <p class="section-eyebrow reveal">Let's Talk</p>
        <h1 class="contact-headline reveal" style="transition-delay:0.08s">
          Start the conversation.
        </h1>
        <p class="contact-sub reveal" style="transition-delay:0.16s">
          Book a free 30-minute call, or send a message below.
          We respond within 1 business day — no pitch deck, no pressure. Ready to discuss your Montana web design, AI automation, or SEO needs.
        </p>
      </div>
    </section>

    <section class="contact-body" style="position:relative;z-index:3">
      <div class="section-container contact-grid">

        <!-- Form -->
        <div class="form-col reveal">
          <h2 class="form-heading">Send a Message</h2>
          <form
            action="https://formspree.io/f/xdabnydk"
            method="POST"
            class="contact-form"
            id="contact-form"
          >
            <label class="field-label">
              Name
              <input type="text" name="name" required placeholder="Your full name" class="field-input" />
            </label>
            <label class="field-label">
              Email
              <input type="email" name="email" required placeholder="you@example.com" class="field-input" />
            </label>
            <label class="field-label">
              Phone <span class="field-optional">(optional)</span>
              <input type="tel" name="phone" placeholder="(406) 000-0000" class="field-input" />
            </label>
            <label class="field-label">
              Message
              <textarea name="message" rows="5" required placeholder="Tell us about your business and what you're looking for..." class="field-input field-textarea"></textarea>
            </label>
            <button type="submit" class="btn-primary form-submit">
              Send My Message
              <span class="btn-arrow" aria-hidden="true">→</span>
            </button>
          </form>
          <div id="form-success" class="form-success hidden" aria-live="polite">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
              <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6.5 11l3 3 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p>Message sent! We'll be in touch within 1 business day.</p>
          </div>
        </div>

        <!-- Booking + info -->
        <div class="info-col reveal" style="transition-delay:0.15s">
          <div class="info-block">
            <h2 class="form-heading">Book a Call</h2>
            <p class="info-text">
              Prefer to talk first? Book a free 30-minute discovery call directly on our calendar. Let's discuss your website, automation, or SEO project.
            </p>
            <a
              href="https://cal.com/mtspin6"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary book-btn"
            >
              Book on Cal.com
              <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          </div>

          <div class="info-block">
            <h3 class="info-label">Email</h3>
            <a href="mailto:contact@mayflywebdesign.com" class="info-link">
              contact@mayflywebdesign.com
            </a>
          </div>

          <div class="info-block">
            <h3 class="info-label">Service Area</h3>
            <p class="info-text">Serving Montana Statewide<br />Missoula · Bozeman · Great Falls · Billings · and beyond<br /><span style="font-size:0.8125rem;opacity:0.75">Web Design · AI Automations · SEO &amp; GAIO</span></p>
          </div>

          <div class="info-block">
            <h3 class="info-label">Response Time</h3>
            <p class="info-text">Within 1 business day. We're fast because we care.</p>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .contact-hero {
    background-color: var(--color-bg);
    padding: 5rem 0 3rem;
    min-height: clamp(240px, 32vh, 440px);
    border-bottom: 1px solid var(--color-surface);
    position: relative;
    overflow: hidden;
  }
  .contact-hero-photo {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1508193638397-1c4234db14d8?w=1920&auto=format&fit=crop&q=80');
    background-size: cover;
    background-position: center 50%;
    z-index: 0;
  }
  .contact-hero-dim {
    position: absolute;
    inset: 0;
    background-color: rgba(22, 22, 20, 0.50);
    z-index: 1;
  }
  .contact-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(3rem, 6.5vw, 5rem);
    letter-spacing: -0.025em;
    color: var(--color-bg);
    margin-bottom: 1.25rem;
  }
  .contact-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(242,237,227,0.72);
    max-width: 44ch;
  }

  .contact-body {
    background-color: var(--color-bg);
    padding: 4rem 0 6rem;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 1024px) {
    .contact-grid { grid-template-columns: 3fr 2fr; gap: 6rem; }
  }

  .form-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    margin-bottom: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .field-label {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .field-optional {
    font-weight: 300;
    color: var(--color-muted);
  }
  .field-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background-color: var(--color-surface);
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s ease;
    -webkit-appearance: none;
    box-sizing: border-box;
  }
  .field-input:focus {
    border-color: var(--color-accent);
  }
  .field-input::placeholder { color: var(--color-muted); }
  .field-textarea {
    resize: vertical;
    min-height: 8rem;
  }
  .form-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }
  @media (min-width: 640px) {
    .form-submit { width: auto; align-self: flex-start; }
  }

  .form-success {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.125rem 1.25rem;
    background-color: rgba(94,126,88,0.1);
    border: 1px solid rgba(94,126,88,0.25);
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
  }
  .hidden { display: none !important; }

  .info-col {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: 0;
  }
  @media (min-width: 1024px) {
    .info-col { padding-top: 3.375rem; }
  }
  .info-block { display: flex; flex-direction: column; gap: 0.5rem; }
  .info-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .info-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text);
  }
  .info-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .info-link:hover { opacity: 0.7; }
  .book-btn { align-self: flex-start; margin-top: 0.5rem; }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' },
    });
    if (res.ok) {
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    }
  });
</script>
