---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

const projects = [
  {
    title:       'Clearwater Outfitters',
    category:    'Websites',
    industry:    'Fly Fishing Outfitter',
    tag:         'Concept',
    desc:        'A high-converting booking site for a Missoula fly fishing guide — built to capture leads and showcase the experience.',
    img:         'https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800&auto=format&fit=crop&q=75',
  },
  {
    title:       'Highline Brewing Co.',
    category:    'Websites',
    industry:    'Brewery',
    tag:         'Concept',
    desc:        'Taproom website with event calendar, menu integration, and online merchandise — built for community and conversion.',
    img:         'https://images.unsplash.com/photo-1546626801-1f9cace5e67e?w=800&auto=format&fit=crop&q=75',
  },
  {
    title:       'Peak HVAC Services',
    category:    'Websites',
    industry:    'Home Services',
    tag:         'Concept',
    desc:        'Local service site with instant quote form, service area map, and review showcase — built to win calls.',
    img:         'https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=800&auto=format&fit=crop&q=75',
  },
  {
    title:       'Ridgeline Coffee',
    category:    'Websites',
    industry:    'Coffee Shop',
    tag:         'Concept',
    desc:        'Warm, editorial café website with menu, hours, and loyalty program — brand-first design with real conversion focus.',
    img:         'https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=800&auto=format&fit=crop&q=75',
  },
  {
    title:       'Big Sky Dental',
    category:    'Websites',
    industry:    'Dentist Office',
    tag:         'Concept',
    desc:        'Clean, trust-building dental website with online booking, insurance info, and new-patient conversion flow.',
    img:         'https://images.unsplash.com/photo-1588776814546-1ffbb2c8a9ef?w=800&auto=format&fit=crop&q=75',
  },
  {
    title:       'Big Sky Realty Co.',
    category:    'Websites',
    industry:    'Real Estate Agency',
    tag:         'Concept',
    desc:        'A clean, high-converting property search experience for a boutique Bozeman real estate agency — built to showcase listings and generate buyer leads.',
    img:         'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=800&auto=format&fit=crop&q=75',
  },
];
---

<BaseLayout
  title="Our Work | Mayfly Web Design — Montana"
  description="Portfolio of websites, AI automations, and SEO projects built by Mayfly Web Design for Montana businesses."
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Our Work — Mayfly Web Design Portfolio",
    "description": "Website concepts and digital projects for Montana businesses across fly fishing, brewery, home services, coffee, dental, and real estate industries.",
    "url": "https://mayflywebdesign.com/work/",
    "isPartOf": { "@type": "WebSite", "name": "Mayfly Web Design", "url": "https://mayflywebdesign.com" }
  })}</script>

  <Header />
  <main id="main-content">
    <section class="page-hero">
      <div class="page-hero-photo" aria-hidden="true"></div>
      <div class="page-hero-dim"   aria-hidden="true"></div>
      <div class="section-container" style="position:relative;z-index:2">
        <p class="section-eyebrow reveal">Portfolio</p>
        <h1 class="page-headline reveal" style="transition-delay:0.08s">
          Montana businesses,<br /><em>built right.</em>
        </h1>
        <p class="page-sub reveal" style="transition-delay:0.16s">
          A selection of website concepts across the niches we serve.
          Real client work added as projects are completed.
        </p>
      </div>
    </section>

    <section class="work-body">
      <div class="section-container">
        <div class="work-grid">
          {projects.map((p, i) => (
            <article class="work-card reveal" style={`transition-delay:${i * 0.08}s`}>
              <div class="work-img-wrap">
                <img
                  src={p.img}
                  alt={`${p.title} website concept`}
                  class="work-img"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  width="800"
                  height="600"
                />
                <div class="work-img-overlay"></div>
              </div>
              <div class="work-meta">
                <span class="work-tag">{p.tag}</span>
                <h3 class="work-title">{p.title}</h3>
                <p class="work-industry">{p.industry}</p>
                <p class="work-desc">{p.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-bg);
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--color-surface);
    position: relative;
    overflow: hidden;
  }
  .page-hero-photo {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&auto=format&fit=crop&q=80');
    background-size: cover;
    background-position: center 35%;
    z-index: 0;
  }
  .page-hero-dim {
    position: absolute;
    inset: 0;
    background-color: rgba(22, 22, 20, 0.50);
    z-index: 1;
  }
  .page-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    letter-spacing: -0.025em;
    color: var(--color-bg);
    margin-bottom: 1.25rem;
  }
  .page-headline em { font-style: italic; color: var(--color-accent); }
  .page-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(242,237,227,0.72);
    max-width: 44ch;
  }

  .work-body { padding: 5rem 0; background-color: var(--color-bg); }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
    background-color: var(--color-surface);
  }
  @media (min-width: 640px) {
    .work-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .work-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .work-card {
    background-color: var(--color-bg);
    overflow: hidden;
    cursor: default;
    transition: background-color 0.2s ease;
  }
  .work-card:hover { background-color: var(--color-surface); }

  .work-img-wrap {
    aspect-ratio: 4/3;
    position: relative;
    overflow: hidden;
  }
  .work-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }
  .work-card:hover .work-img { transform: scale(1.03); }
  .work-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(22,22,20,0.2));
    pointer-events: none;
  }

  .work-meta {
    padding: 1.25rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .work-tag {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.25rem;
  }
  .work-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .work-industry {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 300;
    color: var(--color-muted);
  }
  .work-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-muted);
    margin-top: 0.375rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .work-card:hover .work-desc {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 639px) {
    .work-desc { opacity: 1; transform: none; }
  }
</style>
