---
const services = [
  {
    href:  '/services/website-design',
    label: 'Website Design',
    price: 'Starting at $750',
    desc:  'Custom, fast-loading sites built to convert visitors into clients. Mobile-first, SEO-ready, and delivered on time.',
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="2.5" y="4.5" width="21" height="15" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
      <path d="M9 23h8M13 20v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <path d="M2.5 16h21" stroke="currentColor" stroke-width="1.4"/>
    </svg>`,
  },
  {
    href:  '/services/ai-automations',
    label: 'AI Automations',
    price: 'From $300/automation',
    desc:  'Automated lead follow-up, booking confirmations, and review requests — running while you focus on the work.',
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="13" cy="13" r="10" stroke="currentColor" stroke-width="1.4"/>
      <path d="M13 8v5l3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M6.5 21l3-3M19.5 21l-3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>`,
  },
  {
    href:  '/services/seo-gaio',
    label: 'SEO & GAIO',
    price: '$300/mo maintenance',
    desc:  'Get found by Google and AI tools. We optimize for both—because your customers use both. Local SEO + GAIO for Missoula and Montana businesses.',
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M3 19l6-8 4 4.5 4-6 6 9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="21" cy="7" r="2.5" stroke="currentColor" stroke-width="1.4"/>
    </svg>`,
  },
];
---

<section class="services-wrap">
  <div class="section-container">

    <div class="services-hd reveal">
      <p class="section-eyebrow">What We Build</p>
      <h2 class="section-headline">Three ways we<br />grow your business</h2>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <article
          class="service-card reveal"
          style={`transition-delay:${i * 0.1}s`}
        >
          <div class="card-icon" set:html={s.icon} />
          <p class="card-price">{s.price}</p>
          <h3 class="card-title">{s.label}</h3>
          <p class="card-desc">{s.desc}</p>
          <a href={s.href} class="btn-ghost card-link">
            Learn more
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M2 6.5h9M7 2.5l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-wrap {
    background-color: var(--color-surface);
    padding: 5rem 0;
  }
  @media (min-width: 768px) { .services-wrap { padding: 7rem 0; } }

  .services-hd { margin-bottom: 3.5rem; }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5px;
    background-color: var(--color-muted);
  }
  @media (min-width: 768px) {
    .services-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .service-card {
    background-color: var(--color-surface);
    padding: 2.5rem 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
    transition: background-color 0.22s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .service-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background-color: var(--color-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.28s ease;
  }
  .service-card:hover {
    background-color: var(--color-bg);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(22,22,20,0.10);
  }
  .service-card:hover::before { transform: scaleY(1); }

  .card-icon {
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }
  .card-price {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.4375rem;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin-bottom: 0.25rem;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.68;
    color: var(--color-muted);
    flex: 1;
    margin-bottom: 1rem;
  }
  .card-link { font-size: 0.8125rem; }
</style>
