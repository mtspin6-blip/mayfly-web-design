---
const props = [
  {
    n:     '01',
    title: 'Montana-Local',
    body:  "We're not a national agency treating Montana as an afterthought. We understand your market, your customers, and what it takes to earn trust here.",
  },
  {
    n:     '02',
    title: 'AI-Augmented Delivery',
    body:  'We use modern tooling to ship faster without cutting corners. Better sites, tighter timelines, and prices that work for small business budgets.',
  },
  {
    n:     '03',
    title: 'Full-Stack Digital',
    body:  'Websites, automations, and SEO — under one roof, from one team. No juggling three vendors or chasing down deliverables.',
  },
];
---

<section class="values-wrap">
  <div class="section-container">

    <div class="values-top reveal">
      <p class="section-eyebrow">Why Mayfly</p>
      <div class="values-head-grid">
        <h2 class="section-headline">Built different,<br /><em>on purpose.</em></h2>
        <p class="values-lede">
          Most Montana businesses have been burned by agencies that overpromise and underdeliver.
          We built Mayfly to be the opposite.
        </p>
      </div>
    </div>

    <ul class="values-list" role="list">
      {props.map((p, i) => (
        <li class="value-row reveal" style={`transition-delay:${i * 0.12}s`}>
          <span class="value-n" aria-hidden="true">{p.n}</span>
          <div class="value-body">
            <h3 class="value-title">{p.title}</h3>
            <p class="value-text">{p.body}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .values-wrap {
    background-color: var(--color-bg);
    padding: 5rem 0;
  }
  @media (min-width: 768px) { .values-wrap { padding: 7rem 0; } }

  .values-top { margin-bottom: 4rem; }

  .values-head-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  @media (min-width: 768px) {
    .values-head-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .values-lede {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.72;
    color: var(--color-muted);
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-surface);
    max-width: 40ch;
  }

  .values-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-surface);
  }

  .value-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 2rem;
    padding: 2.25rem 0;
    border-bottom: 1px solid var(--color-surface);
    align-items: start;
    transition: padding-left 0.22s ease, opacity 0.65s ease, transform 0.65s ease;
  }
  .value-row:hover { padding-left: 0.5rem; }

  .value-n {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-muted);
    padding-top: 0.375rem;
  }

  .value-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin-bottom: 0.625rem;
  }
  .value-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 56ch;
  }
</style>
