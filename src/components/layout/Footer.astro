---
import { Image } from 'astro:assets';
import LogoPng from '../../assets/Logo-2x.png';

const year = new Date().getFullYear();

const cols = {
  Services: [
    { href: '/services/website-design/', label: 'Website Design' },
    { href: '/services/ai-automations/', label: 'AI Automations' },
    { href: '/services/seo-gaio/',       label: 'SEO + GAIO' },
  ],
  Company: [
    { href: '/pricing/',  label: 'Pricing' },
    { href: '/work/',     label: 'Our Work' },
    { href: '/about/',    label: 'About' },
    { href: '/contact/',  label: 'Contact' },
  ],
};
---

<footer class="site-footer">
  <div class="section-container footer-inner">

    <div class="footer-top">
      <!-- Brand column -->
      <div class="footer-brand reveal">
        <a href="/" class="footer-logo" aria-label="Mayfly Web Design">
          <Image
            src={LogoPng}
            alt="Mayfly Web Design"
            class="footer-logo-img"
            width={168}
            height={168}
            densities={[1, 2, 3]}
          />
        </a>
        <p class="footer-tagline">Built Modern. Priced for Montana.</p>
        <a href="mailto:contact@mayflywebdesign.com" class="footer-email">
          contact@mayflywebdesign.com
        </a>
        <p class="footer-region">Serving Montana Statewide</p>
      </div>

      <!-- Link columns -->
      {Object.entries(cols).map(([heading, links], ci) => (
        <div class="reveal" style={`transition-delay:${(ci + 1) * 0.1}s`}>
          <p class="col-heading">{heading}</p>
          <ul class="col-links" role="list">
            {links.map(l => (
              <li><a href={l.href} class="col-link">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <!-- CTA column -->
      <div class="reveal" style="transition-delay:0.3s">
        <p class="col-heading">Get Started</p>
        <p class="footer-cta-text">Book a free 30-minute call — no pitch deck, just a real conversation.</p>
        <a href="https://cal.com/mayflywebdesign/discovery" target="_blank" rel="noopener noreferrer" class="btn-primary footer-cta-btn">
          Book a Call
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-legal">&copy; {year} Mayfly Web Design &middot; All rights reserved</p>
      <p class="footer-legal">mayflywebdesign.com</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-text);
    color: var(--color-bg);
    padding: 4.5rem 0 2rem;
    border-top: 2px solid var(--color-accent);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(242,237,227,0.1);
    margin-bottom: 2rem;
  }
  @media (min-width: 640px) {
    .footer-top { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .footer-top { grid-template-columns: 2fr 1fr 1fr 1.5fr; }
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .footer-logo-img {
    height: 48px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1) opacity(0.85);
    object-fit: contain;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(242,237,227,0.55);
    margin-bottom: 1rem;
  }
  .footer-email {
    display: block;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: opacity 0.15s ease;
  }
  .footer-email:hover { opacity: 0.75; }
  .footer-region {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(242,237,227,0.35);
    letter-spacing: 0.04em;
    margin-top: 0.375rem;
  }

  .col-heading {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(242,237,227,0.38);
    margin-bottom: 1rem;
  }
  .col-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .col-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    color: rgba(242,237,227,0.7);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .col-link:hover { color: var(--color-bg); }

  .footer-cta-text {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(242,237,227,0.55);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .footer-cta-btn { display: inline-flex; }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .footer-legal {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(242,237,227,0.3);
  }
</style>
